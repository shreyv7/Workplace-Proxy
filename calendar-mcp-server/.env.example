# ============================================================
# Calendar MCP Server — Environment Variables
# Copy this file to .env and fill in real values.
# ============================================================

PORT=3002

# ── Google OAuth credentials ──────────────────────────────────────────────────
# From: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Same client you configured in Supabase Auth.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Google access token (for demo / single-user setup) ────────────────────────
# Set this to a valid Google OAuth access token with the following scope:
#   https://www.googleapis.com/auth/calendar.readonly
#
# How to get one for local development:
#   1. Complete Google OAuth via the frontend (Sign in with Google)
#   2. Open browser DevTools → Application → Local Storage
#   3. Look for the Supabase session key; the provider_token field is your access token
#   4. Paste it here (tokens expire in ~1 hour; the frontend re-auth flow refreshes them)
#
# When this is NOT set, the server returns realistic demo data instead.
GOOGLE_ACCESS_TOKEN=
