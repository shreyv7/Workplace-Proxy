# ============================================================
# Workplace Proxy — Frontend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ── Role 2 Backend (Multi-Agent Orchestrator) ─────────────────
# URL of the Role 2 FastAPI server. Change the port if you
# override APP_PORT in backend/.env.
VITE_BACKEND_URL=http://localhost:8000

# ── MCP Server URLs (for frontend lib/integrations.ts) ────────
# These must match the PORT values in each MCP server's .env file.
VITE_SLACK_MCP_URL=http://localhost:3000
VITE_GMAIL_MCP_URL=http://localhost:3001
VITE_CALENDAR_MCP_URL=http://localhost:3002
VITE_WHATSAPP_MCP_URL=http://localhost:3003

# ── Qdrant Database Settings ──────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=
