# ============================================================
# Gmail MCP Server — Environment Variables
# Copy this file to .env and fill in real values.
# ============================================================

PORT=3001

# ── Google OAuth credentials ──────────────────────────────────────────────────
# Same client as calendar-mcp-server (Google Cloud project is shared).
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Google access token with Gmail scope ──────────────────────────────────────
# Required scope: https://www.googleapis.com/auth/gmail.readonly
#
# Same token as calendar-mcp-server if you also requested the gmail.readonly scope
# during the Google OAuth consent flow (see frontend Configure button).
#
# When NOT set, the server returns demo email threads.
GOOGLE_ACCESS_TOKEN=
