# ============================================================
# Workplace Proxy — Role 2 Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ── Google Gemini ────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── Lyzr (optional — used by integrations/lyzr_integration.py) ──
LYZR_API_KEY=your_api_key_here
LYZR_ENABLED=true

# ── FastAPI server ────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── CORS (comma-separated list of allowed origins) ───────────
# Use * for development. Set to Vercel URL in production.
CORS_ORIGINS=*

# ── Role 3: Memory / Qdrant service ──────────────────────────
# Update once Role 3 confirms their endpoint.
MEMORY_SERVICE_URL=http://localhost:8001
MEMORY_SERVICE_TIMEOUT=10.0

# ── Role 1: MCP servers ───────────────────────────────────────
# Update once Role 1 confirms Calendar MCP transport.
MCP_CALENDAR_URL=http://localhost:3002
MCP_SLACK_URL=http://localhost:3000
MCP_EMAIL_URL=http://localhost:3001
MCP_TIMEOUT=10.0

# ── Debate engine ─────────────────────────────────────────────
MAX_DEBATE_ROUNDS=3
DEBATE_CONSENSUS_THRESHOLD=2

# ── LLM resilience ───────────────────────────────────────────
LLM_RETRY_COUNT=2
LLM_RETRY_DELAY_SECONDS=1.0

# ── MCP transport ─────────────────────────────────────────────
# Options: http | sse | stdio
MCP_TRANSPORT=http
# Only used when MCP_TRANSPORT=stdio
MCP_STDIO_COMMAND=

# ── Demo mode ─────────────────────────────────────────────────
# Set to true for live demos — returns deterministic response instantly
DEMO_MODE=false

# ── Observability ─────────────────────────────────────────────
MAX_TRANSCRIPT_EVENTS=500

# ── Environment ───────────────────────────────────────────────
ENVIRONMENT=development
