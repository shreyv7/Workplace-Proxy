# ============================================================
# Slack MCP Server — Environment Variables
# Copy this file to .env and fill in real values.
# ============================================================

PORT=3000

# ── Slack App credentials ─────────────────────────────────────────────────────
# From: https://api.slack.com/apps → Your App → Basic Information → App Credentials
#
# Required scopes for the Slack App (OAuth & Permissions):
#   Bot Token Scopes:
#     channels:history   — read messages in public channels
#     channels:read      — list public channels
#     chat:write         — post messages (optional, for future use)
#     users:read         — resolve user names
#
# Redirect URI to add in Slack App → OAuth & Permissions:
#   http://localhost:3000/oauth/callback
#
SLACK_CLIENT_ID=your-slack-app-client-id
SLACK_CLIENT_SECRET=your-slack-app-client-secret

# ── Slack Bot Token (alternative to OAuth flow) ───────────────────────────────
# If you already have a bot token (xoxb-...), set it here to skip the OAuth flow.
# The OAuth flow above stores the token in memory; this env var pre-loads it.
# Get it from: Slack App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=
